#!/usr/bin/env bash
#
# proscala-overlay — drop the Proscala build files from `main` into a code-branch
# checkout so it can be built, without committing them to the branch.
#
# Usage (run from inside a code-branch worktree):
#   bin/proscala-overlay [<stream>]
#
# The build lives on `main`: the Makefile, the per-stream config (mk/), the
# Scala.js scalalib support sources (library-js-aux/), the Scala 2 stdlib-overlay
# list (project/ScalaLibraryFilesToCopy.scala) and the vendored Scala.js IR. This
# copies them into the current worktree as untracked files and adds them (plus
# the build output dirs) to this worktree's git exclude list, so `git status`
# still shows only the branch's own change. Then just run `make`.
#
# The vendored IR is chosen by whether the branch carries the WASM/WIT feature:
# a tree with library-js/.../scala/scalajs/wit uses the scala-wasm IR (its WASM
# backend requires it); any other tree uses its stream's stock Scala.js IR
# (mk/<stream>.mk BASE_SCALAJS_VERSION). The Makefile switches the matching
# scalajs artifacts the same way.
#
# The stream is taken from the argument, else derived from the branch name.
# Override the source ref with PROSCALA_MAIN (default: origin/main, else main).

set -euo pipefail

die() { echo >&2 "proscala-overlay: $*"; exit 1; }

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a git worktree"
cd "$(git rev-parse --show-toplevel)"

MAIN_REF="${PROSCALA_MAIN:-origin/main}"
git rev-parse --verify --quiet "$MAIN_REF^{commit}" >/dev/null 2>&1 || MAIN_REF=main
git rev-parse --verify --quiet "$MAIN_REF:Makefile" >/dev/null 2>&1 \
  || die "no Makefile on '$MAIN_REF' — has the build been moved to main yet?"

# Determine the stream (for the base-IR selection and STREAM default).
stream="${1:-}"
if [ -z "$stream" ]; then
  branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  stream="$(printf '%s\n' "$branch" | awk -F/ 'NF>=2{print $2}')"
fi
[ -n "$stream" ] || die "cannot determine stream from branch; pass it: bin/proscala-overlay 3.10"
git rev-parse --verify --quiet "$MAIN_REF:mk/$stream.mk" >/dev/null 2>&1 \
  || die "unknown stream '$stream' (no mk/$stream.mk on $MAIN_REF)"

# Pick the vendored IR by the WASM/WIT feature marker in *this* worktree.
if [ -f library-js/src/scala/scalajs/wit/package.scala ]; then
  ir="wasm"; flavour="scala-wasm"
else
  base="$(git show "$MAIN_REF:mk/$stream.mk" | sed -nE 's/^BASE_SCALAJS_VERSION[[:space:]]*:=[[:space:]]*([^[:space:]]+).*/\1/p' | head -1)"
  [ -n "$base" ] || die "could not read BASE_SCALAJS_VERSION from mk/$stream.mk"
  ir="base/$base"; flavour="Scala.js $base"
fi
git rev-parse --verify --quiet "$MAIN_REF:mk/scalajs-ir/$ir" >/dev/null 2>&1 \
  || die "no vendored IR at mk/scalajs-ir/$ir on $MAIN_REF"

echo ">> overlaying build files from $MAIN_REF (stream $stream, $flavour IR)"

# Always-overlaid build files, at their natural paths.
git archive "$MAIN_REF" Makefile mk/3.8.mk mk/3.9.mk mk/3.10.mk \
    library-js-aux project/ScalaLibraryFilesToCopy.scala | tar -x

# Selected vendored IR -> compiler/src-scalajs-ir.
rm -rf compiler/src-scalajs-ir
mkdir -p compiler/src-scalajs-ir
git archive "$MAIN_REF" "mk/scalajs-ir/$ir" | tar -x --strip-components=3 -C compiler/src-scalajs-ir

# Keep the branch clean: hide the overlaid files and the build output from
# `git status`, scoped to THIS worktree only. We must not touch the shared
# .git/info/exclude — on a multi-worktree checkout (as Proscala uses) that file
# is common to every worktree, and excluding /Makefile, /mk/ etc. there would
# stop `main` (which tracks them) from staging them. A per-worktree
# core.excludesFile avoids that.
git config extensions.worktreeConfig true
excl="$(git rev-parse --git-dir)/proscala-overlay.excludes"
{
  printf '/%s\n' Makefile mk/ library-js-aux/ compiler/src-scalajs-ir/ \
                 project/ScalaLibraryFilesToCopy.scala bin/proscala-overlay
  printf '%s\n' /release/ /.build/
} > "$excl"
git config --worktree core.excludesFile "$excl"

echo ">> done. Build with:  make          # stream auto-detected from the branch"
echo "                    or  make STREAM=$stream"
